# ── cc-chat 配置 ─────────────────────────────
# 复制为 .env 后填写：cp .env.example .env

# [必填] 共享密钥，relay 和 agent 必须一致
# 生成命令：openssl rand -hex 32
CC_TOKEN=

# ── Relay（Linux 服务器 / Docker）─────────────

# relay 监听端口（默认 17389）
PORT=17389

# ── Agent（本地电脑）──────────────────────────

# relay 的 WebSocket 地址（agent 连接用）
CC_RELAY=wss://你的域名/ws

# Claude Code CLI 路径（留空则自动检测 VS Code 扩展目录）
CC_CMD=

# Anthropic API 配置（可选，留空使用默认）
ANTHROPIC_BASE_URL=
ANTHROPIC_AUTH_TOKEN=
